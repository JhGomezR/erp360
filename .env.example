# ─────────────────────────────────────────────────────────────────────────────
# Variables para docker-compose.yml
# Copiar a .env y completar con valores reales
# ─────────────────────────────────────────────────────────────────────────────

# ── Red del PostgreSQL existente ──────────────────────────────────────────────
# Nombre de la red Docker donde corre tu contenedor de PostgreSQL.
# Verifica con: docker network ls
POSTGRES_NETWORK=postgres_default

# ── Variables públicas del frontend (se incrustan en el build de Next.js) ─────
NEXT_PUBLIC_API_URL=https://tudominio.com/api
NEXT_PUBLIC_REVERB_HOST=tudominio.com
NEXT_PUBLIC_REVERB_PORT=443
NEXT_PUBLIC_REVERB_APP_KEY=tu-reverb-app-key
NEXT_PUBLIC_REVERB_SCHEME=https
