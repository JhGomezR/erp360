<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         stopOnFailure="false"
>
    <testsuites>
        <!-- CAJA BLANCA: lógica interna, sin I/O externo, máxima cobertura de ramas -->
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <!-- CAJA NEGRA / INTEGRACIÓN: endpoints reales, DB SQLite en memoria -->
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
        <!-- CAJA GRIS / SEGURIDAD: XSS, SQLi, IDOR, Auth bypass, Rate limit -->
        <testsuite name="Security">
            <directory>tests/Security</directory>
        </testsuite>
        <!-- RENDIMIENTO: tiempos de respuesta bajo condiciones normales -->
        <testsuite name="Performance">
            <directory>tests/Performance</directory>
        </testsuite>
    </testsuites>

    <source>
        <include>
            <directory>app</directory>
        </include>
        <exclude>
            <directory>app/Console</directory>
        </exclude>
    </source>

    <coverage>
        <report>
            <html outputDirectory="coverage/html"/>
            <text outputFile="coverage/coverage.txt"/>
            <clover outputFile="coverage/clover.xml"/>
        </report>
    </coverage>

    <php>
        <env name="APP_ENV"                value="testing"/>
        <env name="APP_KEY"                value="base64:dGVzdEtleUZvckF0bGFzRVJQVGVzdGluZzEyMzQ1Njc4OTA="/>
        <env name="APP_DEBUG"              value="false"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS"          value="4"/>
        <env name="BROADCAST_CONNECTION"   value="null"/>
        <env name="CACHE_STORE"            value="array"/>
        <env name="DB_CONNECTION"          value="sqlite"/>
        <env name="DB_DATABASE"            value=":memory:"/>
        <env name="DB_URL"                 value=""/>
        <env name="MAIL_MAILER"            value="array"/>
        <env name="QUEUE_CONNECTION"       value="sync"/>
        <env name="SESSION_DRIVER"         value="array"/>
        <env name="PULSE_ENABLED"          value="false"/>
        <env name="TELESCOPE_ENABLED"      value="false"/>
        <env name="NIGHTWATCH_ENABLED"     value="false"/>
        <env name="SANCTUM_STATEFUL_DOMAINS" value="localhost"/>
    </php>
</phpunit>
