# ─────────────────────────────────────────────────────────────────────────────
# Atlas ERP — Variables de entorno para PRODUCCIÓN (Docker)
# Copiar a atlas-backend/.env en el servidor
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME="Atlas ERP"
APP_ENV=production
APP_KEY=base64:GENERAR_CON_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://atlaserp.com.co
APP_FRONTEND_URL=https://atlaserp.com.co

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=error

# ─── Base de Datos (PostgreSQL en Docker externo) ─────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=nombre_de_tu_contenedor_postgres   # ← cambiar por el nombre real del contenedor
DB_PORT=5432
DB_DATABASE=Atlas_ctrlyTli112
DB_USERNAME=uRy3apoloTGs7nPrDDR5
DB_PASSWORD="gJ*hI2mFC89SHUbyTdEkLo4ndyWDI9CQI"
DB_SCHEMA=public

# ─── Sesión / Caché / Colas → Redis (servicio Docker interno) ─────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_DOMAIN=.atlaserp.com.co

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# ─── Redis (servicio 'redis' en docker-compose.yml) ──────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Reverb WebSocket ─────────────────────────────────────────────────────────
REVERB_APP_ID=atlas-erp-prod
REVERB_APP_KEY=GENERAR_CLAVE_ALEATORIA_32_CHARS
REVERB_APP_SECRET=GENERAR_SECRET_ALEATORIO_32_CHARS
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=https

# ─── Correo electrónico ───────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.tuproveedor.com
MAIL_PORT=587
MAIL_USERNAME=tu@email.com
MAIL_PASSWORD=TU_PASSWORD_SMTP
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@atlaserp.com.co"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Almacenamiento ───────────────────────────────────────────────────────────
MEDIA_DISK=local

# ─── Sentry (opcional — activar desde panel central) ─────────────────────────
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Backups ──────────────────────────────────────────────────────────────────
BACKUP_KEEP_LAST=30

# ─── Pasarelas de pago ────────────────────────────────────────────────────────
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=
WOMPI_SANDBOX=false
