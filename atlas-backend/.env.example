APP_NAME="Atlas ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_FRONTEND_URL=http://localhost:3000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Base de Datos (PostgreSQL) ───────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=atlas_central
DB_USERNAME=postgres
DB_PASSWORD=secret
DB_SCHEMA=public

# ─── Sesión / Caché / Colas ──────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Producción: cambiar a 'redis' para procesar emails y jobs en background
QUEUE_CONNECTION=redis

CACHE_STORE=redis

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Correo electrónico ───────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@atlaserp.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Almacenamiento de archivos ───────────────────────────────────────────────
# local: archivos en storage/app/public
# s3: Amazon S3 o compatible (DigitalOcean Spaces, MinIO, etc.)
MEDIA_DISK=local

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Tenancy (stancl/tenancy) ─────────────────────────────────────────────────
TENANCY_DB_TEMPLATE=
# Prefijo de schema por tenant: {slug}_axcys
# Se configura en config/tenancy.php

# ─── Pasarelas de pago ────────────────────────────────────────────────────────
# MercadoPago (Colombia / Latam)
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# Stripe (internacional)
STRIPE_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Wompi (Colombia)
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=
WOMPI_SANDBOX=true

# ─── DIAN Factura Electrónica ─────────────────────────────────────────────────
# Requiere certificado .p12 y credenciales habilitación DIAN
DIAN_NIT=
DIAN_SOFTWARE_ID=
DIAN_SOFTWARE_PIN=
DIAN_CERT_PATH=
DIAN_CERT_PASSWORD=
DIAN_ENVIRONMENT=2
# 1 = produccion DIAN, 2 = habilitacion DIAN

# ─── Notificaciones y webhooks ────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

VITE_APP_NAME="${APP_NAME}"
VITE_API_URL="${APP_URL}"
